# 复制此文件为 .env.local 并填入真实值 (.env.local 已被 .gitignore 排除)
# 在 Supabase 控制台 Project Settings → API 找到这两个值
#
# Supabase 2025+ 引入新的 publishable key(以 sb_publishable_ 开头),
# 旧的 anon JWT key 仍然兼容。任选一种填到 NEXT_PUBLIC_SUPABASE_ANON_KEY 即可。

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY